# The Sharp Shoppe — Environment Variables
# Copy this file to .env and fill in your keys

# Shippo API Key (get from https://apps.goshippo.com/settings/api)
# Use shippo_test_xxxx for testing (free, generates real-looking test labels)
# Use shippo_live_xxxx for production (charges real postage)
SHIPPO_API_KEY=shippo_test_YOUR_KEY_HERE

# Stripe Publishable Key (frontend)
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Stripe Secret Key (backend — never expose to frontend)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# PayPal Client ID (Live)
# Get from https://developer.paypal.com/dashboard/applications/live
# Already embedded in order.html PayPal JS SDK script tag
PAYPAL_CLIENT_ID=ARA8pZM6FAdD6UK4Bx9luIpymHz0uNA4g-nS1s6hPNun7RUGYQQ5lc98X2-hZ2y0N8ZRXCKX4YwUNe7z

# Coinbase Commerce API Key
# Get from https://commerce.coinbase.com/dashboard/settings (after account verification)
COINBASE_COMMERCE_API_KEY=YOUR_COINBASE_COMMERCE_API_KEY

# Google OAuth Client ID
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Server port
PORT=3001
